# --- Environment ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Database / Queue ---
# For local dev keep SQLite. On Render this is provided automatically.
DATABASE_URL=sqlite:///./local.db
REDIS_URL=redis://localhost:6379/0

# --- External APIs ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-5

GHL_PRIVATE_TOKEN=pit-...
GHL_LOCATION_ID=...
GHL_API_BASE=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28

# --- Notifications ---
ADMIN_EMAIL=gad@morethan.com
RESEND_API_KEY=re_...

# --- Limits ---
MAX_UPLOAD_MB=500
TRANSCRIPT_CHUNK_MINUTES=10
