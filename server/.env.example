# --- Environment ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Database / Queue ---
# For local dev keep SQLite. On Render this is provided automatically.
DATABASE_URL=sqlite:///./local.db
REDIS_URL=redis://localhost:6379/0

# --- External APIs ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
# Haiku is ~12x cheaper than opus and plenty for call/meeting summaries.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

GHL_PRIVATE_TOKEN=pit-...
GHL_LOCATION_ID=...
GHL_API_BASE=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28

# --- Notifications ---
ADMIN_EMAIL=gad@morethan.com
RESEND_API_KEY=re_...
# Sender for admin alerts (e.g. "out of API credit"). MUST be a Resend-verified
# domain/address or alerts fail silently (logged, never crashes the pipeline).
ALERT_FROM_EMAIL=alerts@morethan.com

# --- Limits ---
MAX_UPLOAD_MB=500
TRANSCRIPT_CHUNK_MINUTES=10
